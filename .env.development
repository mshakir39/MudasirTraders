# React 19 Development Environment Variables
# Fix memory leak warnings in development

# Increase Node.js memory limit
NODE_OPTIONS=--max-old-space-size=4096

# Disable Next.js telemetry to reduce event listeners
NEXT_TELEMETRY_DISABLED=1

# React 19 development optimizations
FAST_REFRESH=true
TURBOPACK=1

# Suppress memory leak warnings (development only)
NODE_NO_WARNINGS=1
